# MEZA environment variables
# Copy to .env.local for local development. On Vercel/Render, set these in
# the platform's environment-variable settings instead.

# Supabase -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase -> Project Settings -> API -> anon public key (safe for browsers;
# all data access is enforced by Row Level Security).
# New Supabase projects call this the "publishable" key (sb_publishable_...);
# either env var name below works - set whichever matches your dashboard.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# The service role key must never be shipped to the browser - it bypasses
# Row Level Security. It IS required on the deployed web app itself for the
# handful of server-only routes with no restaurant-owner session to
# authenticate with (app/api/cron/recommendations, app/api/capture/[token]/*
# for the unauthenticated device capture page), same reasoning as the edge
# scripts in cv_pipeline/ and edge_sensors/. Set it as a server-only env var
# on Vercel/Render (never a NEXT_PUBLIC_ variable).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# This app's own public base URL, used to construct the QR-code capture
# link shown on /devices (e.g. https://meza-yourapp.onrender.com). Must be
# HTTPS in production - getUserMedia/DeviceMotion on the phone capture page
# require a secure context. http://localhost is fine for local dev only.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Demo mode (optional) ---
# Credentials for the read-only demo account created by `npm run seed:demo`.
# NEXT_PUBLIC_* copies are what the "Try Demo" button on the sign-in page
# uses to sign in as this account client-side; the RLS policies in
# supabase/migrations/003_demo_mode.sql make its restaurant read-only
# regardless of who is signed into it.
# DEMO_EMAIL=demo@meza.app
# DEMO_PASSWORD=MezaDemo2026!
# NEXT_PUBLIC_DEMO_EMAIL=demo@meza.app
# NEXT_PUBLIC_DEMO_PASSWORD=MezaDemo2026!
