generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Enums are stored as strings in SQLite
// Channel: DIRECT, SWIGGY, ZOMATO, UBER_EATS, WHATSAPP
// OrderStatus: COMPLETED, VOIDED, REFUNDED
// PaymentMethod: CASH, CARD, UPI, WALLET
// OrderType: DINE_IN, TAKEAWAY, DELIVERY
// StaffRole: WAITER, CHEF, BARTENDER, MANAGER, CASHIER
// AlertType: THEFT_SUSPECTED, STOCK_LOW, STOCK_EXPIRING, VOID_PATTERN, SALES_SPIKE
// Severity: LOW, MEDIUM, HIGH, CRITICAL
// MovementType: PURCHASE, USAGE, WASTE, THEFT

enum ShiftType {
  BREAKFAST
  LUNCH
  EVENING
  DINNER
}

enum SignalType {
  DISH_REQUEST
  DISH_COMPLAINT
  EARLY_BILL
  UPSELL_WIN
  UPSELL_FAIL
  TABLE_FEEDBACK
  POSITIVE_SHOUTOUT
  OTHER
}

enum SessionRole {
  OWNER
  MANAGER
  WAITER
}

enum PrefTier {
  MEDIUM
  CUSTOM
}

model Restaurant {
  id          Int              @id @default(autoincrement())
  name        String
  ownerId     String?
  phone       String?
  language    String           @default("en") // hi, ta, bn
  currency    String           @default("INR")
  gstNumber   String?

  orders      Order[]
  menuItems   MenuItem[]
  inventory   InventoryItem[]
  staff       Staff[]
  alerts      Alert[]
  servers     Server[]
  aggregates  TimeAggregate[]
  insights    Insight[]
  decisions   Decision[]
  simulations Simulation[]
  suppliers   Supplier[]
  customers   Customer[]
  customerArchetypes CustomerArchetype[]
  tableClusters TableCluster[]
  waiterSignals WaiterSignal[]
  whatsappSessions WhatsAppSession[]
  whatsappPreferences WhatsAppPreference[]
  whatsappInbound WhatsAppInbound[]
  users       User[]
  contextualAssociations ContextualAssociation[]
  digestLogs  DigestLog[]
  createdAt   DateTime         @default(now())
}

model User {
  id           String            @id @default(cuid())
  restaurantId Int?
  phone        String?           @unique
  name         String?
  role         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  restaurant   Restaurant?       @relation(fields: [restaurantId], references: [id])
  whatsappPreference WhatsAppPreference?
  whatsappSessions   WhatsAppSession[]

  @@index([restaurantId])
}

model Order {
  id            Int         @id @default(autoincrement())
  externalId    String?
  restaurantId  Int
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  orderNumber   String?
  orderDate     DateTime?
  timestamp     DateTime
  orderType     String      @default("DINE_IN") // DINE_IN, TAKEAWAY, DELIVERY
  channel       String      @default("DIRECT") // DIRECT, SWIGGY, ZOMATO, UBER_EATS, WHATSAPP

  subtotal      Float       @default(0)
  tax           Float       @default(0)
  discount      Float       @default(0)
  platformFee   Float       @default(0)
  totalAmount   Float

  serverId      Int?
  server        Server?     @relation(fields: [serverId], references: [id])
  staffId       Int?
  staff         Staff?      @relation(fields: [staffId], references: [id])
  orderItems    OrderItem[]

  status        String      @default("COMPLETED") // COMPLETED, VOIDED, REFUNDED
  voidReason    String?
  voidedBy      String?

  paymentMethod String?     // CASH, CARD, UPI, WALLET
  customerPhone String?
  guestCount    Int?

  metadata      String?
  createdAt     DateTime    @default(now())
  customerVisit CustomerVisit?

  @@index([restaurantId, timestamp])
  @@index([timestamp])
  @@index([channel, status])
}

model OrderItem {
  id              Int       @id @default(autoincrement())
  orderId         Int
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId      Int
  menuItem        MenuItem  @relation(fields: [menuItemId], references: [id])
  quantity        Int
  priceAtTime     Float
  unitCost        Float     @default(0) // COGS
  discountAmount  Float     @default(0)
  total           Float     @default(0)
  preparationTime Int?      // minutes taken
  createdAt       DateTime  @default(now())

  @@index([menuItemId])
  @@index([orderId])
}

model MenuItem {
  id              Int              @id @default(autoincrement())
  restaurantId    Int
  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id])
  name            String
  nameHindi       String?
  category        String?
  currentPrice    Float
  cost            Float?
  margin          Float?           // price - cost

  preparationTime Int              @default(10)
  station         String?          // TANDOOR, WOK, BAR

  isVeg           Boolean          @default(true)
  spiceLevel      Int              @default(0)

  isActive        Boolean          @default(true)
  swiggyPrice     Float?
  zomatoPrice     Float?

  // Analytics (auto-calculated)
  popularity      Float            @default(0)
  salesCount      Int              @default(0)
  classification  String?          // STAR, PLOWHORSE, PUZZLE, DOG

  orderItems      OrderItem[]
  baselines       ItemBaseline[]
  ingredients     MenuIngredient[]
  waiterSignals   WaiterSignal[]
  associationsFrom ContextualAssociation[] @relation("AssociationItemA")
  associationsTo ContextualAssociation[] @relation("AssociationItemB")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([restaurantId])
  @@unique([restaurantId, name])
}

model MenuIngredient {
  id              Int           @id @default(autoincrement())
  menuItemId      Int
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id])
  inventoryItemId Int
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  quantity        Float
  unit            String        // kg, liter, piece

  @@index([menuItemId])
  @@index([inventoryItemId])
}

model InventoryItem {
  id              Int              @id @default(autoincrement())
  restaurantId    Int
  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id])
  name            String
  category        String           // PROTEIN, DAIRY, VEGETABLE, LIQUOR

  currentStock    Float            @default(0)
  unit            String           // kg, liter, piece
  minStock        Float            @default(0) // Reorder threshold

  costPerUnit     Float            @default(0)
  usageRate       Float            @default(0) // units/day

  isPerishable    Boolean          @default(false)
  shelfLifeDays   Int?
  storageLocation String?          // FREEZER, FRIDGE, BAR

  supplierId      Int?
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])

  ingredients     MenuIngredient[]
  movements       StockMovement[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([restaurantId])
  @@unique([restaurantId, name])
}

model StockMovement {
  id              Int           @id @default(autoincrement())
  inventoryItemId Int
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  type            String        // PURCHASE, USAGE, WASTE, THEFT
  quantity        Float
  cost            Float?

  reason          String?
  recordedBy      String
  recordedAt      DateTime      @default(now())

  // Blind audit
  expectedStock   Float?
  actualStock     Float?
  variance        Float?

  @@index([inventoryItemId])
}

model Supplier {
  id               Int             @id @default(autoincrement())
  restaurantId     Int
  restaurant       Restaurant      @relation(fields: [restaurantId], references: [id])
  name             String
  phone            String?
  creditTerms      Int             @default(0) // days
  reliabilityScore Float           @default(5.0)

  inventory        InventoryItem[]
  createdAt        DateTime        @default(now())

  @@index([restaurantId])
}

model Staff {
  id              Int        @id @default(autoincrement())
  restaurantId    Int
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  name            String
  role            String     // WAITER, CHEF, BARTENDER, MANAGER, CASHIER

  ordersServed    Int        @default(0)
  voidCount       Int        @default(0)
  voidAmount      Float      @default(0)
  suspicionScore  Float      @default(0) // ML calculated

  orders          Order[]
  createdAt       DateTime   @default(now())

  @@index([restaurantId])
}

model Alert {
  id              Int        @id @default(autoincrement())
  restaurantId    Int
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  type            String     // THEFT_SUSPECTED, STOCK_LOW, STOCK_EXPIRING, VOID_PATTERN, SALES_SPIKE
  severity        String     // LOW, MEDIUM, HIGH, CRITICAL

  title           String
  titleHindi      String?
  message         String

  relatedStaffId  Int?
  isRead          Boolean    @default(false)

  createdAt       DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@index([type, severity])
}

model Server {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name         String
  externalId   String?
  orders       Order[]
  waiterSignals WaiterSignal[]
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}

model TimeAggregate {
  id             Int        @id @default(autoincrement())
  restaurantId   Int
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  periodType     String
  periodStart    DateTime
  periodEnd      DateTime
  totalRevenue   Float
  totalOrders    Int
  avgOrderValue  Float
  totalItems     Int
  uniqueItems    Int
  hourOfDay      Int?
  dayOfWeek      Int?
  computedAt     DateTime   @default(now())
  version        Int        @default(1)
  
  @@unique([restaurantId, periodType, periodStart, periodEnd, version])
  @@index([restaurantId, periodType, periodStart])
}

model ItemBaseline {
  id                 Int      @id @default(autoincrement())
  menuItemId         Int
  menuItem           MenuItem @relation(fields: [menuItemId], references: [id])
  periodStart        DateTime
  periodEnd          DateTime
  avgDailyQuantity   Float
  stdDevQuantity     Float
  avgDailyRevenue    Float
  stdDevRevenue      Float
  priceElasticity    Float?
  seasonalityIndex   Float?
  trendSlope         Float?
  sampleSize         Int
  confidenceScore    Float
  computedAt         DateTime @default(now())
  version            Int      @default(1)
  
  @@unique([menuItemId, periodEnd, version])
  @@index([menuItemId, periodEnd])
}

model Insight {
  id              Int        @id @default(autoincrement())
  restaurantId    Int
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  type            String
  severity        String
  observation     String
  explanation     String
  causalFactors   String
  formula         String
  assumptions     String
  sampleSize      Int?
  confidenceScore Float
  recommendation  String?
  decisionId      Int?       @unique
  decision        Decision?  @relation(fields: [decisionId], references: [id])
  createdAt       DateTime   @default(now())
  expiresAt       DateTime?
  
  @@index([restaurantId, createdAt])
  @@index([type, severity])
}

model Decision {
  id              Int              @id @default(autoincrement())
  restaurantId    Int
  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id])
  type            String
  entityType      String
  entityId        Int?
  recommendation  String
  rationale       String
  predictedImpact String
  simulationId    Int?
  simulation      Simulation?      @relation(fields: [simulationId], references: [id])
  status          String           @default("pending")
  userFeedback    String?
  implementedAt   DateTime?
  outcome         DecisionOutcome?
  insight         Insight?
  createdAt       DateTime         @default(now())
  
  @@index([restaurantId, status])
  @@index([entityType, entityId])
}

model DecisionOutcome {
  id             Int      @id @default(autoincrement())
  decisionId     Int      @unique
  decision       Decision @relation(fields: [decisionId], references: [id])
  actualImpact   String
  accuracyScore  Float
  errorAnalysis  String
  beforeMetrics  String
  afterMetrics   String
  evaluatedAt    DateTime @default(now())
  daysSinceImpl  Int
  
  @@index([accuracyScore])
}

model Simulation {
  id                 Int        @id @default(autoincrement())
  restaurantId       Int
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id])
  type               String
  inputParams        String
  assumptions        String
  assumptionSource   String
  projectedMetrics   String
  confidenceScore    Float
  sensitivityData    String?
  decisions          Decision[]
  createdAt          DateTime   @default(now())
  
  @@index([restaurantId, type])
}

model Customer {
  id               String              @id @default(cuid())
  restaurantId     Int
  phone            String?
  zomatoId         String?
  swiggyId         String?
  displayName      String?
  archetypeId      String?
  firstSeenAt      DateTime
  lastSeenAt       DateTime
  visitCount       Int                 @default(1)
  totalSpend       Float               @default(0)
  avgOrderValue    Float               @default(0)
  preferredChannel String?
  preferredTime    String?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  restaurant       Restaurant          @relation(fields: [restaurantId], references: [id])
  archetype        CustomerArchetype?  @relation(fields: [archetypeId], references: [id])
  visits           CustomerVisit[]
  signals          CustomerSignal[]

  @@index([restaurantId, phone])
  @@index([restaurantId, zomatoId])
  @@index([restaurantId, swiggyId])
}

model CustomerVisit {
  id         String   @id @default(cuid())
  customerId String
  orderId    Int      @unique
  visitedAt  DateTime
  partySize  Int?
  channel    String
  totalSpend Float
  tableNumber String?
  serverId   Int?
  notes      String?

  customer   Customer @relation(fields: [customerId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
  server     Server?  @relation(fields: [serverId], references: [id])

  @@index([customerId, visitedAt])
  @@index([orderId])
}

model WaiterSignal {
  id             String     @id @default(cuid())
  restaurantId   Int
  serverId       Int?
  shiftDate      DateTime
  shiftType      ShiftType
  signalType     SignalType
  body           String
  bodyNormalized String?
  menuItemId     Int?
  sentiment      Float?
  processed      Boolean    @default(false)
  createdAt      DateTime   @default(now())

  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  server         Server?    @relation(fields: [serverId], references: [id])
  menuItem       MenuItem?  @relation(fields: [menuItemId], references: [id])

  @@index([restaurantId, createdAt])
  @@index([menuItemId, signalType])
}

model CustomerSignal {
  id         String     @id @default(cuid())
  customerId String
  type       SignalType
  body       String
  orderId    Int?
  createdAt  DateTime   @default(now())

  customer   Customer   @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
}

model CustomerArchetype {
  id             String     @id @default(cuid())
  restaurantId   Int
  name           String
  description    String
  avgSpend       Float
  avgPartySize   Float
  preferredTime  String
  preferredChannel String
  visitFrequency String
  customerCount  Int
  revenueShare   Float
  topItems       Json
  computedAt     DateTime   @default(now())

  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  customers      Customer[]

  @@index([restaurantId, computedAt])
}

model TableCluster {
  id              String     @id @default(cuid())
  restaurantId    Int
  tableNumber     String
  dayOfWeek       Int
  timeband        String
  avgPartySize    Float
  avgSpend        Float
  dominantChannel String
  visitCount      Int
  probabilityRepeat Float
  computedAt      DateTime   @default(now())

  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, tableNumber, dayOfWeek, timeband])
}

model WhatsAppSession {
  id            String      @id @default(cuid())
  phone         String
  restaurantId  Int
  userId        String?
  role          SessionRole
  state         String
  context       Json        @default("{}")
  lastMessageAt DateTime    @default(now())
  expiresAt     DateTime
  createdAt     DateTime    @default(now())

  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  user          User?       @relation(fields: [userId], references: [id])

  @@index([restaurantId, phone])
  @@index([expiresAt])
}

model WhatsAppPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  restaurantId         Int
  digestEnabled        Boolean  @default(true)
  digestTime           String   @default("08:00")
  digestDays           Json     @default("[1,2,3,4,5,6,7]")
  wantsMenuInsights    Boolean  @default(true)
  wantsChannelInsights Boolean  @default(true)
  wantsServerInsights  Boolean  @default(true)
  wantsAssocInsights   Boolean  @default(true)
  wantsArchetypeInsights Boolean @default(true)
  wantsCustomerInsights Boolean @default(true)
  revenueDropThreshold Float?
  revpashMinThreshold  Float?
  channelMarginMin     Float?
  dogItemMinOrders     Int?
  alertOnRevenueDrop   Boolean  @default(false)
  alertOnLowRevpash    Boolean  @default(false)
  alertOnChannelDrain  Boolean  @default(false)
  alertOnNewArchetype  Boolean  @default(false)
  tier                 PrefTier @default(MEDIUM)

  user                 User      @relation(fields: [userId], references: [id])
  restaurant           Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

model WhatsAppInbound {
  id          String     @id @default(cuid())
  from        String
  restaurantId Int?
  body        String
  intent      String?
  handledBy   String?
  sessionId   String?
  receivedAt  DateTime   @default(now())

  restaurant  Restaurant? @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, receivedAt])
  @@index([from, receivedAt])
}

model ContextualAssociation {
  id          String   @id @default(cuid())
  restaurantId Int
  itemAId     Int
  itemBId     Int
  timeband    String
  channel     String
  partySizeBucket String
  serverTier  String
  support     Float
  confidence  Float
  lift        Float
  occurrences Int
  estimatedWeeklyUplift Float
  trainabilityScore Float
  computedAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  itemA      MenuItem   @relation("AssociationItemA", fields: [itemAId], references: [id])
  itemB      MenuItem   @relation("AssociationItemB", fields: [itemBId], references: [id])

  @@unique([restaurantId, itemAId, itemBId, timeband, channel, partySizeBucket, serverTier])
  @@index([restaurantId, itemAId, lift])
}

model DigestLog {
  id          String   @id @default(cuid())
  restaurantId Int
  userId      String?
  phone       String
  messageType String
  status      String
  reason      String?
  message     String?
  createdAt   DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])

  @@index([restaurantId, createdAt])
  @@index([phone, createdAt])
  @@index([messageType, createdAt])
}
