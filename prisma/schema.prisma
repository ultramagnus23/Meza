generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                String   @id @default(cuid())
  name              String
  city              String   @default("")
  timezone          String   @default("Asia/Kolkata")
  currency          String   @default("INR")
  totalSeats        Int      @default(40)
  hoursOpen         Float    @default(12)
  posSystem         PosType  @default(MANUAL)
  posWebhookSecret  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             RestaurantUser[]
  orders            Order[]
  menuItems         MenuItem[]
  servers           Server[]
  digestConfigs     DigestConfig[]
  digestLogs        DigestLog[]
  associations      ItemAssociation[]
  snapshots         DailySnapshot[]
}

enum PosType {
  PETPOOJA
  URBANPIPER
  SQUARE
  MANUAL
  CSV_IMPORT
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  phone         String?
  passwordHash  String?
  googleId      String?  @unique
  role          UserRole @default(MANAGER)
  createdAt     DateTime @default(now())

  restaurants   RestaurantUser[]
  accounts      Account[]
  sessions      Session[]
}

enum UserRole {
  OWNER
  MANAGER
  VIEWER
}

model RestaurantUser {
  id            String     @id @default(cuid())
  userId        String
  restaurantId  String
  role          UserRole
  receiveDigest Boolean    @default(true)
  digestTime    String     @default("08:00")

  user          User       @relation(fields: [userId], references: [id])
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, restaurantId])
}

model Order {
  id             String      @id @default(cuid())
  restaurantId   String
  externalId     String?
  channel        Channel
  serverId       String?
  tableNumber    String?
  subtotal       Float
  tax            Float       @default(0)
  discount       Float       @default(0)
  total          Float
  partySize      Int?
  orderedAt      DateTime
  completedAt    DateTime?
  createdAt      DateTime    @default(now())

  restaurant     Restaurant  @relation(fields: [restaurantId], references: [id])
  server         Server?     @relation(fields: [serverId], references: [id])
  items          OrderItem[]
}

enum Channel {
  DINE_IN
  TAKEAWAY
  ZOMATO
  SWIGGY
  DIRECT_DELIVERY
  OTHER
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  menuItemId   String
  quantity     Int
  unitPrice    Float
  totalPrice   Float

  order        Order    @relation(fields: [orderId], references: [id])
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
}

model MenuItem {
  id             String   @id @default(cuid())
  restaurantId   String
  externalId     String?
  name           String
  category       String
  price          Float
  costPrice      Float    @default(0)
  prepTimeMin    Int      @default(10)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  restaurant     Restaurant  @relation(fields: [restaurantId], references: [id])
  orderItems     OrderItem[]
  associationsA  ItemAssociation[] @relation("ItemA")
  associationsB  ItemAssociation[] @relation("ItemB")
}

model Server {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  orders       Order[]
}

model ItemAssociation {
  id             String   @id @default(cuid())
  restaurantId   String
  itemAId        String
  itemBId        String
  support        Float
  confidence     Float
  lift           Float
  occurrences    Int
  computedAt     DateTime @default(now())

  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  itemA          MenuItem   @relation("ItemA", fields: [itemAId], references: [id])
  itemB          MenuItem   @relation("ItemB", fields: [itemBId], references: [id])

  @@unique([restaurantId, itemAId, itemBId])
  @@index([restaurantId, lift(sort: Desc)])
}

model DailySnapshot {
  id              String   @id @default(cuid())
  restaurantId    String
  date            DateTime @db.Date
  totalRevenue    Float
  totalOrders     Int
  avgOrderValue   Float
  revpash         Float
  topItemId       String?
  topChannelName  String?
  coverCount      Int
  createdAt       DateTime @default(now())

  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  @@unique([restaurantId, date])
}

model DigestConfig {
  id             String   @id @default(cuid())
  restaurantId   String   @unique
  isEnabled      Boolean  @default(true)
  sendTime       String   @default("08:00")
  timezone       String   @default("Asia/Kolkata")
  lookbackDays   Int      @default(7)
  maxInsights    Int      @default(5)
  includeRevenue Boolean  @default(true)
  includeMenu    Boolean  @default(true)
  includeChannel Boolean  @default(true)
  includeServer  Boolean  @default(true)

  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
}

model DigestLog {
  id             String        @id @default(cuid())
  restaurantId   String
  sentAt         DateTime      @default(now())
  recipientPhone String
  status         DigestStatus
  whatsappMsgId  String?
  messageBody    String
  insightCount   Int
  errorMessage   String?

  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
}

enum DigestStatus {
  SENT
  FAILED
  PENDING
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}
